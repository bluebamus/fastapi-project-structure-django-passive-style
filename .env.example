# =============================================================================
# 애플리케이션 설정
# =============================================================================
# 프로젝트 이름 (Scalar 문서 제목, 관리자 페이지 제목에 표시)
PROJECT_NAME=fastapi-sqlamin-celery

# 애플리케이션 버전 (헬스체크 API 응답에 포함)
VERSION=1.0.0

# 프로젝트 설명 (Scalar 문서에 표시)
DESCRIPTION=SQLAlchemy admin과 Celery를 사용한 FastAPI 프로젝트

# DEBUG 모드 설정 (기본값: true)
# - true: DEBUG 로그 출력, 테이블 자동 생성, uvicorn reload 활성화, /docs 활성화
# - false: INFO 로그만 출력, 테이블 자동 생성 비활성화 (Alembic 사용), /docs 비활성화
DEBUG=true

# ADMIN 페이지 설정 (기본값: true)
# - true: /admin 관리자 페이지 접근 가능 (SQLAdmin)
# - false: /admin 관리자 페이지 접근 차단
# Note: DEBUG 설정과 독립적으로 동작합니다.
ADMIN=true

# 환경 설정: development(개발), staging(스테이징), production(운영)
# 헬스체크 API 응답에 포함됨
ENV=development

# 개발 서버(main.py __main__) 바인드 주소/포트
# 안전 기본값은 127.0.0.1(루프백). 컨테이너/외부 노출이 필요하면 HOST=0.0.0.0 로 설정.
HOST=127.0.0.1
PORT=8000

# =============================================================================
# 타임존 설정
# =============================================================================
# 애플리케이션 전역 타임존 (로그 시간, 데이터 생성 시간 등에 적용)
# 예시: Asia/Seoul, UTC, America/New_York
TIME_ZONE=Asia/Seoul

# =============================================================================
# 데이터베이스 설정 (MySQL)
# =============================================================================
# MySQL 서버 호스트 (IP 또는 도메인)
MYSQL_HOST=localhost

# MySQL 서버 포트
MYSQL_PORT=3306

# MySQL 접속 사용자명
MYSQL_USER=root

# MySQL 접속 비밀번호
MYSQL_PASSWORD=your_password

# 사용할 데이터베이스 이름
MYSQL_DATABASE=fastapi_db

# =============================================================================
# DB 라우터 (읽기/쓰기 분리)
# =============================================================================
# 라우터 사용 여부 (기본값: false)
# - false: 모든 쿼리가 위에서 설정한 단일 서버로 나간다 (기존 동작)
# - true : 세션이 구문 성격에 따라 엔진을 자동 선택한다
#          · ORM flush / INSERT·UPDATE·DELETE → primary(쓰기)
#          · SELECT                            → replica(읽기)
#          · 쓰기가 일어난 세션의 이후 SELECT  → primary 고정 (아래 STICKY 참고)
# 구현: app/core/db/router.py
DB_ROUTER_ENABLED=false

# 읽기 복제본(replication) 사용 여부 (기본값: false)
# - true 로 켜려면 DB_ROUTER_ENABLED=true 와 MYSQL_REPLICA_HOSTS 지정이 함께 필요하다.
#   (모순된 조합은 애플리케이션 기동 시점에 에러로 차단된다)
# - false: 라우터를 켜도 replica 가 없으므로 읽기도 primary 로 나간다.
DB_REPLICATION_ENABLED=false

# 쓰기 이후 같은 세션의 읽기를 primary 에 고정 (기본값: true, 권장)
# 복제 지연(replication lag) 때문에 방금 커밋한 행이 replica 에서 아직 안 보일 수 있다.
# false 로 두면 읽기 분산은 늘어나지만 read-after-write 일관성을 잃는다.
DB_READ_STICKY_AFTER_WRITE=true

# replica 호스트 목록 (JSON 배열, "host" 또는 "host:port" 형식)
# 여러 대를 지정하면 세션 단위 라운드로빈으로 분산된다.
# 호스트는 IP 주소와 도메인 이름을 모두 쓸 수 있고, 포트를 생략하면 MYSQL_REPLICA_PORT 를 쓴다.
#   IPv4   : ["10.0.0.11", "10.0.0.12:3307"]
#   도메인 : ["replica-a.example.com", "replica-b.example.com:3307"]
#   IPv6   : ["[2001:db8::10]:3307", "[::1]"]   ← 반드시 대괄호로 감쌀 것
# 예: MYSQL_REPLICA_HOSTS=["10.0.0.11", "replica-b.example.com:3307"]
MYSQL_REPLICA_HOSTS=[]

# 포트를 명시하지 않은 replica 에 적용할 기본 포트
MYSQL_REPLICA_PORT=3306

# replica 전용 자격증명 (비워두면 위 primary 값을 그대로 재사용)
# 읽기 전용 계정을 따로 두면 실수로 replica 에 쓰는 사고를 DB 권한으로 막을 수 있다.
# MYSQL_REPLICA_USER=readonly
# MYSQL_REPLICA_PASSWORD=readonly_password
# MYSQL_REPLICA_DATABASE=fastapi_db

# =============================================================================
# 마이그레이션 (Alembic)
# =============================================================================
# Alembic 이 사용할 DSN. 미설정 시 위 primary 설정에서 자동 유도한다
# (드라이버만 동기용 pymysql 로 치환 — Alembic 은 비동기 드라이버를 쓸 수 없다).
# 로컬/CI 에서 SQLite 등으로 갈아끼울 때만 명시한다.
# 마이그레이션은 항상 primary 에서 실행된다 (replica 는 읽기 전용).
# ALEMBIC_DATABASE_URL=sqlite:///./test.db

# =============================================================================
# Redis 설정 (캐시, 세션 등에 사용)
# =============================================================================
# Redis 서버 호스트
REDIS_HOST=localhost

# Redis 서버 포트
REDIS_PORT=6379

# Redis 데이터베이스 번호 (0-15)
REDIS_DB=0

# Redis 비밀번호 (설정하지 않으면 인증 없이 접속)
REDIS_PASSWORD=

# =============================================================================
# CORS 설정 (Cross-Origin Resource Sharing)
# =============================================================================
# 허용할 Origin 목록 (JSON 배열 형식)
# 모든 Origin 허용: ["*"]
# 특정 Origin만 허용: ["http://localhost:3000", "https://example.com"]
CORS_ALLOW_ORIGINS=["*"]

# 자격 증명(쿠키, Authorization 헤더) 허용 여부
CORS_ALLOW_CREDENTIALS=true

# 허용할 HTTP 메서드 (JSON 배열 형식)
CORS_ALLOW_METHODS=["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]

# 허용할 HTTP 헤더 (JSON 배열 형식)
CORS_ALLOW_HEADERS=["*"]

# 브라우저(JS)에 노출할 응답 헤더 (JSON 배열 형식)
# CORS_EXPOSE_HEADERS=["X-Total-Count"]

# Preflight 요청 캐시 시간 (초)
CORS_MAX_AGE=600

# =============================================================================
# 로깅 설정
# =============================================================================
# 콘솔 로그 출력 활성화
LOG_CONSOLE_ENABLED=true

# 파일 로그 출력 활성화
LOG_FILE_ENABLED=true

# 로그 레벨 설정 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# 미설정 시 DEBUG 설정에 따라 자동 결정:
#   - DEBUG=true → DEBUG 레벨
#   - DEBUG=false → INFO 레벨
# 명시적 설정 시 해당 값이 우선 적용됨
# LOG_LEVEL=DEBUG
# LOG_CONSOLE_LEVEL=DEBUG

# 파일 로그 레벨 (파일에는 INFO 이상만 기록하는 것이 일반적)
LOG_FILE_LEVEL=INFO

# 로그 파일 저장 디렉토리 (프로젝트 루트 기준 상대 경로)
LOG_DIR=logs

# 단일 로그 파일 최대 크기 (MB)
# 초과 시 자동으로 새 파일 생성 (RotatingFileHandler)
LOG_MAX_SIZE_MB=10

# 보관할 백업 로그 파일 개수
LOG_BACKUP_COUNT=5

# 로그 파일명 패턴 ({date} 는 YYYY-MM-DD 로 치환)
# LOG_APP_FILENAME={date}_app.log
# LOG_ERROR_FILENAME={date}_error.log

# 로그 출력 형식 (str.format 스타일)
# LOG_CONSOLE_FORMAT=[{asctime}] {levelname:8} [{name}:{funcName}:{lineno}] {message}
# LOG_FILE_FORMAT=[{asctime}] {levelname:8} [{name}:{funcName}:{lineno}] {message}
# LOG_DATE_FORMAT=%Y-%m-%d %H:%M:%S

# =============================================================================
# 미들웨어 설정
# =============================================================================
# 접속 로그 수집 활성화
# true: 모든 API 요청에 대해 접속 로그를 DB에 저장
ACCESS_LOG_ENABLED=true

# 접속 로그 수집 제외 경로 (JSON 배열 형식)
# 헬스체크, 정적 파일 등 로깅이 불필요한 경로
# ACCESS_LOG_EXCLUDE_PATHS=["/health", "/docs", "/openapi.json", "/admin"]

# 접속 로그 수집 제외 확장자 (JSON 배열 형식)
# 정적 파일 요청은 로깅에서 제외
# ACCESS_LOG_EXCLUDE_EXTENSIONS=[".css", ".js", ".ico", ".png", ".jpg"]

# =============================================================================
# API 설정
# =============================================================================
# REST API 버전 (URL prefix에 사용: /api/v1/...)
API_VERSION=v1

# =============================================================================
# 세션 설정
# =============================================================================
# 세션 쿠키 이름
SESSION_COOKIE_NAME=session

# 세션 암호화 키 (보안을 위해 반드시 변경 필요)
# 생성 방법: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=your-secret-key-change-this-in-production

# 세션 만료 시간 (초, 기본값: 86400 = 24시간)
# SESSION_EXPIRE_SECONDS=86400

# =============================================================================
# JWT 토큰 설정
# =============================================================================
# Access Token 암호화 키 (보안을 위해 반드시 변경 필요)
# 생성 방법: openssl rand -hex 32
ACCESS_TOKEN_SECRET_KEY=your-access-token-secret-key-change-this

# Refresh Token 암호화 키 (Access Token과 다른 키 사용 권장)
# 생성 방법: openssl rand -hex 32
REFRESH_TOKEN_SECRET_KEY=your-refresh-token-secret-key-change-this

# Access Token 만료 시간 (분, 기본값: 30분)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh Token 만료 시간 (일, 기본값: 7일)
REFRESH_TOKEN_EXPIRE_DAYS=7

# JWT 알고리즘 (기본값: HS256)
# JWT_ALGORITHM=HS256

# =============================================================================
# SMTP 이메일 설정
# =============================================================================
# SMTP 서버 주소 (로컬 개발: localhost, Gmail: smtp.gmail.com)
SMTP_SERVER=localhost

# SMTP 서버 포트
# - 25: 로컬 개발용 (비암호화)
# - 587: TLS (운영 환경 권장)
# - 465: SSL
SMTP_PORT=25

# SMTP 인증 사용자명 (일반적으로 이메일 주소)
SMTP_USERNAME=your-email@example.com

# SMTP 인증 비밀번호
# Gmail의 경우 앱 비밀번호 사용 필요 (2단계 인증 활성화 후 생성)
SMTP_PASSWORD=your-app-password

# 발신자 이메일 주소 (미설정 시 SMTP_USERNAME 사용)
# SMTP_FROM_EMAIL=noreply@example.com

# 발신자 이름 (미설정 시 PROJECT_NAME 사용)
# SMTP_FROM_NAME=FastAPI Project

# TLS 사용 여부 (포트 587 사용 시 true)
SMTP_TLS=false

# SSL 사용 여부 (포트 465 사용 시 true)
SMTP_SSL=false

# =============================================================================
# 이미지 업로드 설정
# =============================================================================
# 업로드된 이미지 자동 리사이즈 활성화
UPLOAD_IMAGE_RESIZE=false

# 업로드 이미지 최대 크기 (MB)
UPLOAD_IMAGE_SIZE_LIMIT=20

# 리사이즈 최대 너비 (px, UPLOAD_IMAGE_RESIZE=true 시 적용)
UPLOAD_IMAGE_RESIZE_WIDTH=1200

# 리사이즈 최대 높이 (px, UPLOAD_IMAGE_RESIZE=true 시 적용)
UPLOAD_IMAGE_RESIZE_HEIGHT=2800

# 이미지 압축 품질 (0-100, 기본값: 85)
# 값이 높을수록 품질은 좋지만 파일 크기 증가
UPLOAD_IMAGE_QUALITY=85

# 허용되는 이미지 확장자 (JSON 배열 형식)
# UPLOAD_ALLOWED_EXTENSIONS=[".jpg", ".jpeg", ".png", ".gif", ".webp"]

# 업로드 파일 저장 경로 (프로젝트 루트 기준 상대 경로)
UPLOAD_DIR=uploads
